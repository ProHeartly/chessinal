#board-grid {
    layout: grid;
    grid-size: 8 8;
    grid-columns: 1fr;
    grid-rows: 1fr;
    width: 80;
    height: 34;
    align: center middle;
    border: round gold;
}

Button {
    width: 10;
    height: 4;
    border: none;
    content-align: center middle;
}

.light {
    background: #ebecd0;
    color: #779556;
}

.dark {
    background: #779556;
    color: #ebecd0;
}

.selected {
    text-style: italic;
}